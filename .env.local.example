# ──────────────────────────────────────────────────────────────────────────────────────────
# HandyANDY Email Configuration
# ──────────────────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# The contact form will NOT send emails without these.
#
# For Gmail: use an App Password (not your regular password).
# Generate one at: https://myaccount.google.com/apppasswords

EMAIL_USERNAME=your-gmail@gmail.com
EMAIL_PASSWORD=your-app-password-here
RECEIVER_EMAIL=where-to-receive-emails@gmail.com

# ──────────────────────────────────────────────────────────────────────────────────────────
# Postgre connection with Prisma
# ──────────────────────────────────────────────────────────────────────────────────────────
# This is the standard connection string for self-hosted PostgreSQL.
# If you dont have a password setup, you can just skip it entirely
#
# Documentation: https://www.prisma.io/docs/orm/core-concepts/supported-databases/postgresql

DATABASE_URL=postgresql://user:pass@host:5432/database