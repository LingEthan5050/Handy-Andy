# ──────────────────────────────────────────────────────────────────────────────────────────
# HandyANDY Email Configuration
# ──────────────────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# The contact form will NOT send emails without these.
#
# For Gmail: use an App Password (not your regular password).
# Generate one at: https://myaccount.google.com/apppasswords

EMAIL_USERNAME=your-gmail@gmail.com
EMAIL_PASSWORD=your-app-password-here
RECEIVER_EMAIL=where-to-receive-emails@gmail.com

# ──────────────────────────────────────────────────────────────────────────────────────────
# Postgre connection with Prisma
# ──────────────────────────────────────────────────────────────────────────────────────────
# This is the standard connection string for self-hosted PostgreSQL.
# If you dont have a password setup, you can just skip it entirely
#
# Documentation: https://www.prisma.io/docs/orm/core-concepts/supported-databases/postgresql

DATABASE_URL=postgresql://user:pass@host:5432/database

# ──────────────────────────────────────────────────────────────────────────────────────────
# Google's OAuth Platform
# ──────────────────────────────────────────────────────────────────────────────────────────
#
# Go to Google's console and create a new project and follow the steps.
# Search up Google Auth Platform and generate your secrets

AUTH_GOOGLE_ID=xxxxxxxxxxxxxxxx.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=xxxxxxxxxxxxxxxx

# ──────────────────────────────────────────────────────────────────────────────────────────
# NextAuth Secret Key & URL
# ──────────────────────────────────────────────────────────────────────────────────────────
#
# Generate by running the command in the root of your project: 
# npx auth secret

AUTH_SECRET=...
NEXTAUTH_URL=http://localhost:3000


# ──────────────────────────────────────────────────────────────────────────────────────────
# Cloudinary Secrets
# ──────────────────────────────────────────────────────────────────────────────────────────
#
# Create an account here: https://cloudinary.com/

NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=my-cloud-name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=abcdefghijklmnopqrstuvwxyz

# ──────────────────────────────────────────────────────────────────────────────────────────
# Upstash Redis
# ──────────────────────────────────────────────────────────────────────────────────────────
#
# Create an account here: https://upstash.com/

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=